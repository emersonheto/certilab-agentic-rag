APP_NAME="Certilab Agentic RAG"
ENVIRONMENT=local
# mock keeps the public course repository runnable without external services.
# real enables local operator-provided MySQL/S3/OpenAI integrations.
APP_MODE=mock
GRAPH_ENGINE=langgraph
DATA_DIR=data
DEFAULT_TOP_K=4

# Local/demo authentication only. These non-secret values are used by the
# X-Demo-Token header in the MVP. Production must replace this with verified
# Laravel/JWT/session identity before creating a Principal.
DEMO_ADMIN_TOKEN=<DEMO_ADMIN_TOKEN>
DEMO_TECHNICIAN_TOKEN=<DEMO_TECHNICIAN_TOKEN>
DEMO_CLIENT_101_TOKEN=<DEMO_CLIENT_101_TOKEN>
DEMO_CLIENT_202_TOKEN=<DEMO_CLIENT_202_TOKEN>
CHAINLIT_DEMO_TOKEN=

# Optional OpenAI integration. Leave empty in mock mode.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional web/vector integrations. Leave empty unless you run those services locally.
TAVILY_API_KEY=
QDRANT_URL=http://localhost:6333
# Qdrant collection name and optional API key (for Qdrant Cloud).
QDRANT_COLLECTION=certilab-rag
QDRANT_API_KEY=
# Embedding provider selection: auto (default, OpenAI with local fallback),
# openai (OpenAI only), local (sentence-transformers offline).
EMBEDDING_PROVIDER=auto
# sentence-transformers model used for local/offline embeddings.
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# Reserved for future DSN-based MySQL support. Current real mode uses DB_* below.
MYSQL_READONLY_DSN=

# Laravel-compatible MySQL aliases. Use a read-only database user; never commit values.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Preferred S3 names for this RAG service.
S3_BUCKET_NAME=
AWS_REGION=us-east-1

# Laravel-compatible AWS/S3 aliases. Never commit credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_STORAGE_PREFIX=
CERTIFICATES_STORAGE_DISK=

# Optional Phoenix/OpenInference tracing. Disabled by default so mock mode runs
# without Phoenix or OpenTelemetry installed.
PHOENIX_ENABLED=false
PHOENIX_PROJECT_NAME=certilab-agentic-rag
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
